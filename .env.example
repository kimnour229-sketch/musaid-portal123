# ============================================================
# Musaid Portal — Environment Configuration (example)
# Copy to ".env" and fill in real values. NEVER commit ".env".
#   cp .env.example .env
# Loaded automatically at startup if python-dotenv is installed.
# ============================================================

# --- Environment: "production" (default) or "development" ---
MUSAID_ENV=production

# --- Debug ---
# Ignored in production (always False there). In development defaults to True.
# MUSAID_DEBUG=0

# --- Session signing key (REQUIRED in production) ---
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
MUSAID_SECRET_KEY=replace-with-a-64-char-hex-secret

# --- Secure cookies ---
# Defaults: ON in production, OFF in development.
# Set to 0 ONLY for local HTTP testing. Must be 1 behind HTTPS.
MUSAID_COOKIE_SECURE=1

# --- Bind address/port for the built-in dev server (dev only) ---
# In production Gunicorn binds the socket instead (see gunicorn.conf.py).
MUSAID_HOST=127.0.0.1
MUSAID_PORT=5000

# ============================================================
# Database backend
# ------------------------------------------------------------
# Default (nothing set) = SQLite (musaid_ist.db) — unchanged behavior.
#
# To use MySQL/MariaDB, set EITHER a full DATABASE_URL ...
#   DATABASE_URL=mysql+pymysql://musaid:your_password@localhost/musaid_portal
#
# ... OR the discrete parts below (used only when DATABASE_URL is empty).
# Setting MUSAID_DB_BACKEND=mysql also forces the MySQL driver.
# ============================================================
# DATABASE_URL=mysql+pymysql://musaid:your_password@localhost/musaid_portal
# MUSAID_DB_BACKEND=mysql
# MYSQL_USER=musaid
# MYSQL_PASSWORD=your_password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=musaid_portal
